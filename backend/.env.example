# Скопируй в .env и подставь значения после ./setup.sh
# .env НИКОГДА не коммитится (см. backend/.gitignore)

# ID каталога Yandex Cloud (yc config get folder-id)
FOLDER_ID=

# Имя/ID Service Account, под которым работает функция (создаёт setup.sh)
SA_NAME=pizza-max-fn-sa
SA_ID=

# Имя/ID секрета в Yandex Lockbox с ключами token, chat_id (создаёт setup.sh)
SECRET_NAME=pizza-max-bot
SECRET_ID=

# Имя cloud function (создаёт deploy.sh при первом запуске)
FN_NAME=pizza-max-order
